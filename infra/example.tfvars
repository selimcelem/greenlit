region            = "eu-central-1"
anthropic_api_key = "sk-ant-replace-me"

# Pin to the actual chrome-extension://<id> once the extension is published.
# Wildcards ("*") are rejected by variable validation.
allowed_origins = ["chrome-extension://REPLACE_WITH_REAL_EXTENSION_ID"]

# ── Lemon Squeezy ─────────────────────────────────────────────────────────
# Create the three products manually in the LS dashboard (Greenlit Starter
# €3/mo, Greenlit Pro €6/mo, Greenlit Max €12/mo) with Tax inclusive pricing
# ON so buyers pay exactly the displayed amount. Paste the resulting IDs:
lemonsqueezy_store_id           = "REPLACE_WITH_LS_STORE_ID"
lemonsqueezy_variant_id_starter = "REPLACE_WITH_STARTER_VARIANT_ID"
lemonsqueezy_variant_id_pro     = "REPLACE_WITH_PRO_VARIANT_ID"
lemonsqueezy_variant_id_max     = "REPLACE_WITH_MAX_VARIANT_ID"
